  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_EmptyStreet
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: 
    text: The street is empty. No motorbikes. No tea shop chatter.
  - speaker: 
    text: A dog stands at the corner without moving. Its eyes don't follow you.
  - speaker: 
    text: You should check on your family.
