  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_BajeOutside
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Baje
    text: Stay close. Do not let them see you.
  - speaker: Baje
    text: In this state you are unfinished. They are drawn to that.
  - speaker: Lele
    text: "\u2026that figure at the end of the street. Who is it?"
  - speaker: Baje
    text: Don't ask. Move. Karuna may not still be Karuna.
