  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_DevrajCameo
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Devraj
    text: So. Another pilgrim, fresh from the foothills.
  - speaker: Devraj
    text: You learned the bond? The slow way? The kind one?
  - speaker: Devraj
    text: I prefer mine faster. The spirits do not consent. They comply.
  - speaker: Devraj
    text: We will meet again at Vajrasana. Try not to die before then.
