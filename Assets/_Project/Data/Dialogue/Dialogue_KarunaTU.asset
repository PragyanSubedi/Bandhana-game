  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_KarunaTU
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Karuna
    text: There you are! Took you long enough.
  - speaker: Karuna
    text: I found this in front of my house yesterday evening.
  - speaker: Karuna
    text: "It's a damaru \u2014 like the ones the sadhus carry."
  - speaker: Karuna
    text: "Bhotu won't stop barking at it. Look \u2014 go on. Try it."
