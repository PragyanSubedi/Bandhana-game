  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_SisterIdle
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Sister
    text: Bhaiya, do you know any songs? I know seven.
  - speaker: Sister
    text: I forgot four of them. The other three are extremely good though.
  - speaker: Sister
    text: One of them is just the word 'momo' said different ways. It's an art piece.
  - speaker: Sister
    text: Don't tell Mama. She doesn't understand my creative process.
