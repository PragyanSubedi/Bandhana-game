  m_Name: Dialogue_KarunaPostBoss
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Karuna
    text: "Lele\u2026?"
  - speaker: Karuna
    text: "I couldn't stop hearing it\u2026"
  - speaker: 
    text: "The damaru cracks faintly \u2014 light leaks from inside."
  - speaker: Baje
    text: You didn't win. You interrupted it.
  - speaker: Baje
    text: Now it knows you can interfere.
