  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_KarunaPyre
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Karuna-la (memory)
    text: You stand by the pyre. The smoke rises to no one in particular.
  - speaker: Karuna-la (memory)
    text: "When I am gone \u2014 and that will be soon \u2014 take the drum."
  - speaker: Karuna-la (memory)
    text: Walk east, until you cannot any longer. Whatever you find, do not force
      it.
  - speaker: Karuna-la (memory)
    text: Sit with it. Hear its rhythm. The bond comes after.
