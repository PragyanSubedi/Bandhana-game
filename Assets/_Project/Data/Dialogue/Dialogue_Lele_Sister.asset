  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_Lele_Sister
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Sister
    text: Bhaiya. Bhaiya. BHAIYA. I have an announcement.
  - speaker: Sister
    text: "When I am older \u2014 like, eleven \u2014 I am going to be a music star."
  - speaker: Sister
    text: Like really really famous. Bigger than that one with the hair. The hair
      one.
  - speaker: Sister
    text: People will paint my face on motorbikes. And buses. Maybe one airplane.
  - speaker: Mom
    text: Eat your dal.
  - speaker: Sister
    text: I'm describing my future, Mama!
  - speaker: Mom
    text: Describe it with food in your mouth.
  - speaker: Sister
    text: (whispers) You can be in my videos, Bhaiya. As a backup person. Standing
      behind me. Mostly.
  - speaker: Sister
    text: But you have to fix your hair first. It looks like a goat slept on it.
