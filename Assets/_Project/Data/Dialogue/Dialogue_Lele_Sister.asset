  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_Lele_Sister
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Sister
    text: Bhaiya! When I'm older I'm going to be a music star.
  - speaker: Sister
    text: Like really really famous. People will paint my face on motorbikes.
  - speaker: Sister
    text: You can be in my videos. Maybe. If you're nice.
