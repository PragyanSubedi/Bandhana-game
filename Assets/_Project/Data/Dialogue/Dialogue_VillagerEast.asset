  m_Script: {fileID: 11500000, guid: e1b77b3898bac999e908216c0f6bf6e3, type: 3}
  m_Name: Dialogue_VillagerEast
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Villager
    text: The stream is silent for the first time in my long life.
  - speaker: Villager
    text: "Whatever Karuna-la was investigating \u2014 it is bigger than us."
  - speaker: Villager
    text: Take the path east when you are ready. The foothills are crying.
