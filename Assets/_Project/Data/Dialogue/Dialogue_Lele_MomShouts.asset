  m_Name: Dialogue_Lele_MomShouts
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: Mom (downstairs)
    text: "Lele!\u2026 Lele!!"
  - speaker: Mom (downstairs)
    text: It's almost three in the afternoon!
  - speaker: Mom (downstairs)
    text: Were you on that game all night again? Get down here!
  - speaker: 
    text: You sit up. The bedroom is too bright. Your eyes hurt.
