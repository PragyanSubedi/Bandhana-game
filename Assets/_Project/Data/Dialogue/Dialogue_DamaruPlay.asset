  m_Name: Dialogue_DamaruPlay
  m_EditorClassIdentifier: Assembly-CSharp::Bandhana.Data.DialogueSO
  lines:
  - speaker: 
    text: You pick up the damaru. The skin is warm. Warmer than it should be.
  - speaker: 
    text: You twist your wrist. The beads strike.
  - speaker: 
    text: "Dum\u2026 dum\u2026 dum\u2026"
